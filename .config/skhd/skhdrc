alt - p: skhd -k "alt - 0x18"
alt + shift - i: skhd -k "alt - 0x17"
alt + shift - o: skhd -k "alt - 0x1B"
alt + shift - u: skhd -k "alt - 0x15"
alt + shift - p: skhd -k "alt - 0x18"
