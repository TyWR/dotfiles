<leader>f	plugin/ranger.vim	/^  map <leader>f :Ranger<CR>$/;"	m
OpenRanger	plugin/ranger.vim	/^function! OpenRanger()$/;"	f
OpenRangerIn	plugin/ranger.vim	/^  function! OpenRangerIn(path, edit_cmd)$/;"	f
OpenRangerOnVimLoadDir	plugin/ranger.vim	/^function! OpenRangerOnVimLoadDir(argv_path)$/;"	f
Ranger	plugin/ranger.vim	/^command! Ranger RangerCurrentFile$/;"	c
RangerCurrentDirectory	plugin/ranger.vim	/^command! RangerCurrentDirectory call OpenRangerIn("%:p:h", s:default_edit_cmd)$/;"	c
RangerCurrentDirectoryExistingOrNewTab	plugin/ranger.vim	/^command! RangerCurrentDirectoryExistingOrNewTab call OpenRangerIn("%:p:h", 'tab drop ')$/;"	c
RangerCurrentDirectoryNewTab	plugin/ranger.vim	/^command! RangerCurrentDirectoryNewTab call OpenRangerIn("%:p:h", 'tabedit ')$/;"	c
RangerCurrentFile	plugin/ranger.vim	/^command! RangerCurrentFile call OpenRangerIn("%", s:default_edit_cmd)$/;"	c
RangerCurrentFileExistingOrNewTab	plugin/ranger.vim	/^command! RangerCurrentFileExistingOrNewTab call OpenRangerIn("%", 'tab drop ')$/;"	c
RangerCurrentFileNewTab	plugin/ranger.vim	/^command! RangerCurrentFileNewTab call OpenRangerIn("%", 'tabedit ')$/;"	c
RangerNewTab	plugin/ranger.vim	/^command! RangerNewTab RangerCurrentDirectoryNewTab$/;"	c
RangerWorkingDirectory	plugin/ranger.vim	/^command! RangerWorkingDirectory call OpenRangerIn(".", s:default_edit_cmd)$/;"	c
RangerWorkingDirectoryExistingOrNewTab	plugin/ranger.vim	/^command! RangerWorkingDirectoryExistingOrNewTab call OpenRangerIn(".", 'tab drop ')$/;"	c
RangerWorkingDirectoryNewTab	plugin/ranger.vim	/^command! RangerWorkingDirectoryNewTab call OpenRangerIn(".", 'tabedit ')$/;"	c
ReplaceNetrwByRangerVim	plugin/ranger.vim	/^  augroup ReplaceNetrwByRangerVim$/;"	a
s:choice_file_path	plugin/ranger.vim	/^    let s:choice_file_path = g:ranger_choice_file$/;"	v
s:choice_file_path	plugin/ranger.vim	/^  let s:choice_file_path = '\/tmp\/chosenfile'$/;"	v
s:default_edit_cmd	plugin/ranger.vim	/^  let s:default_edit_cmd='edit '$/;"	v
s:default_edit_cmd	plugin/ranger.vim	/^  let s:default_edit_cmd='tabedit '$/;"	v
s:ranger_command	plugin/ranger.vim	/^  let s:ranger_command = 'ranger'$/;"	v
s:ranger_command	plugin/ranger.vim	/^  let s:ranger_command = g:ranger_command_override$/;"	v
